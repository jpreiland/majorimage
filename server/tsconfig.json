{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "typeRoots": ["./node_modules/@types"],
    "outDir": "./dist",
    "allowImportingTsExtensions": true
  },
  "include": ["routes/**/*.ts", "data/**/*.ts", "scripts/**/*.ts"]
}